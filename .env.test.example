# Use the same DB URL as `.env` in your current setup, or point to a dedicated test DB.
DATABASE_URL="postgresql://postgres:password@localhost:5432/nexus"
# Optional direct connection string for Prisma Migrate (non-pooler URL).
DIRECT_URL="postgresql://postgres:password@localhost:5432/nexus"

# Base URL for Playwright E2E
TEST_BASE_URL=http://127.0.0.1:3000

# Prefix used for all test-created records
TEST_PREFIX=nexus-e2e

# Seeded admin credentials for E2E admin tests
E2E_ADMIN_EMAIL=nexus-e2e-admin@example.test
E2E_ADMIN_PASSWORD=AdminPass123!

# Test-only payment/auth secrets
PAYSTACK_SECRET_KEY=sk_test_replace_me
NEXTAUTH_SECRET=test-nextauth-secret-change-me

# Optional email config for local integration testing
RESEND_API_KEY=re_test_replace_me
RESEND_FROM_EMAIL="Nexus Enterprises <notifications@example.com>"
RESEND_REPLY_TO="support@example.com"
