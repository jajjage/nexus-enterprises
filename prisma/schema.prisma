generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum OrderStatus {
  AWAITING_PAYMENT
  PAYMENT_CONFIRMED
  IN_PROGRESS
  ACTION_REQUIRED
  COMPLETED
  CANCELLED
}

enum PaymentProvider {
  PAYSTACK
  FLUTTERWAVE
}

enum ServiceStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Order {
  id              String          @id @default(cuid())
  orderNumber     String          @unique
  trackingToken   String          @unique
  serviceId       String?
  service         Service?        @relation(fields: [serviceId], references: [id])
  serviceSlug     String
  serviceName     String
  clientName      String
  clientEmail     String
  clientPhone     String
  companyName     String?
  status          OrderStatus     @default(AWAITING_PAYMENT)
  amountKobo      Int?
  paymentProvider PaymentProvider?
  paymentReference String?
  logs            OrderLog[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([createdAt])
  @@index([status, createdAt])
  @@index([serviceId])
}

model OrderLog {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String
  createdAt DateTime    @default(now())
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

model Post {
  id         String   @id @default(uuid())
  title      String
  slug       String   @unique
  excerpt    String?
  content    String
  coverImage String?
  published  Boolean  @default(false)
  readTime   Int?
  authorName String   @default("Admin")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Subscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model AdminUser {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String // Hashed password
  role      String   @default("ADMIN") // For future multi-user scaling
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  summary     String
  description String
  category    String
  imageUrl    String
  amountKobo  Int?
  status      ServiceStatus @default(DRAFT)
  displayOrder Int          @default(0)
  orders      Order[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status, displayOrder])
}
